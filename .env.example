# Host-side app defaults (`python -m src.server`) when MongoDB/Chroma run via
# `docker compose up -d mongodb chroma`.
MONGODB_URI=mongodb://localhost:27018
DB_NAME=agent_memory

# Host-side Chroma connection
CHROMA_ENABLED=true
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_SSL=false
CHROMA_COLLECTION_NAME=memory_bge_m3_v1

# Shared embedding model settings (any public Hugging Face / sentence-transformers id)
EMBEDDING_MODEL_NAME=dragonkue/BGE-m3-ko
EMBEDDING_DEVICE=cpu
EMBEDDING_CACHE_DIR=
EMBEDDING_MAX_CHARS=1200

# Keep false for first Docker MCP registration so startup does not block on model download.
# After the model is fully cached, you can switch this to true to reduce first-recall latency.
PRELOAD_EMBEDDING_MODEL=false

# MCP transport
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8002
MCP_HTTP_PATH=/mcp

# Docker-only app container overrides
DOCKER_MONGODB_URI=mongodb://mongodb:27017
DOCKER_CHROMA_HOST=chroma
DOCKER_CHROMA_PORT=8000
DOCKER_EMBEDDING_CACHE_DIR=/app/.cache/models

# Centroid staleness policy (days)
CENTROID_STALE_DAYS=14

# Recall scoring
SIMILARITY_WEIGHT=15.0
